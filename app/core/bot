# ==== Ассистент BioSynth-EDU ======================
import streamlit as st
import json
from pathlib import Path
import openai

@st.cache_data
def load_tutor_knowledge():
    """Загружает bot_knowledge_new.json и catalog.json"""
    data = {"kb": {}, "catalog": []}
    try:
        # 1. Инструкции и знания о приложении
        kb_path = Path("data/bot_knowledge_new.json")
        if kb_path.exists():
            with open(kb_path, "r", encoding="utf-8") as f:
                data["kb"] = json.load(f)
        
        # 2. Каталог молекул
        cat_path = Path("data/catalog.json")
        if cat_path.exists():
            with open(cat_path, "r", encoding="utf-8") as f:
                loaded = json.load(f)
                data["catalog"] = loaded if isinstance(loaded, list) else []
                
        return data
             
    except Exception as e:
        st.error(f"❌ Ошибка загрузки данных: {e}")
        return data


def ask_ai_tutor(user_query, data):
    try:
        kb = data.get("kb", {})
        catalog = data.get("catalog", [])
        
        # === Подготовка списка молекул ===
        molecule_list = []
        for mol in catalog:
            if isinstance(mol, dict):
                name = mol.get("name", "Unknown")
                classification = mol.get("classification", "")
                molecule_list.append(f"{name} ({classification})")
        
        all_molecules_str = "\n".join(molecule_list) if molecule_list else "Список молекул пуст"

        # === Поиск данных по выбранной молекуле ===
        selected_mol = st.session_state.get('selected_mol_name', None) or st.session_state.get('current_mol_name', 'Не выбрана')
        mol_data_context = ""
        
        if selected_mol and str(selected_mol).strip() not in ["Не выбрана", "None", "", None]:
            search_name = str(selected_mol).strip().lower()
            for mol in catalog:
                if isinstance(mol, dict) and str(mol.get("name", "")).strip().lower() == search_name:
                    mol_data_context = f"\n\n**ДАННЫЕ ИЗ КАТАЛОГА ПО {selected_mol}:**\n{json.dumps(mol, ensure_ascii=False, indent=2)}"
                    break
            else:
                mol_data_context = f"\n\n⚠️ Данные для '{selected_mol}' не найдены в catalog.json"

        # === Текущее состояние ===
        current_state = {
            "active_tab": st.session_state.get('main_tabs_active', 'Education'),
            "selected_molecule": selected_mol
        }

        # === Запрос к ИИ ===
        client = openai.OpenAI(
            base_url="https://openrouter.ai/api/v1",
            api_key=st.secrets["OPENROUTER_API_KEY"],
        )

        response = client.chat.completions.create(
            extra_headers={
                "HTTP-Referer": "https://biosynth-edu.streamlit.app/",
                "X-OpenRouter-Title": "BioSynth-EDU",
            },
            model="openrouter/free",
            messages=[
                {
                    "role": "system",
                    "content": f"""Ты — ИИ-Тьютор платформы BioSynth-EDU.

**КАТАЛОГ КАЗАХСТАНСКИХ СОЕДИНЕНИЙ:**
{all_molecules_str}

{mol_data_context}

**ЗНАНИЯ О ПРИЛОЖЕНИИ И НАВИГАЦИИ:**
{json.dumps(kb, ensure_ascii=False, indent=2)}

**ТЕКУЩЕЕ СОСТОЯНИЕ:**
{json.dumps(current_state, ensure_ascii=False)}

**СТРОГИЕ ПРАВИЛА:**
1. О свойствах молекул отвечай **ТОЛЬКО** на основе данных из catalog.json.
2. Если информации нет — честно говори, что в локальной базе таких данных нет.
3. По возможностям приложения, навигации, ADMET, PASS используй знания из bot_knowledge_new.
4. Не выдумывай факты (SMILES, Pa/Pi и т.д.).
5. Отвечай профессионально, полезно и на языке пользователя.
"""
                },
                {"role": "user", "content": user_query}
            ],
            temperature=0.3,
        )

        return response.choices[0].message.content

    except Exception as e:
        return f"❌ Ошибка Тьютора: {str(e)}"


@st.dialog("🤖 ИИ-Тьютор BioSynth-EDU")
def tutor_dialog():
    """Диалоговое окно с Тьютором"""
    data = load_tutor_knowledge()

    if "tutor_history" not in st.session_state:
        st.session_state.tutor_history = []

    chat_container = st.container(height=450)

    with chat_container:
        for msg in st.session_state.tutor_history:
            with st.chat_message(msg["role"]):
                st.markdown(msg["content"])

    if prompt := st.chat_input("Задайте вопрос тьютору (о молекулах, пособии, навигации)..."):
        st.session_state.tutor_history.append({"role": "user", "content": prompt})
        with chat_container:
            with st.chat_message("user"):
                st.markdown(prompt)

        with st.spinner("Думаю..."):
            answer = ask_ai_tutor(prompt, data)

        st.session_state.tutor_history.append({"role": "assistant", "content": answer})
        st.rerun()
